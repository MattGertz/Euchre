<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUIEuchre.EuchreBid2Control"
             WidthRequest="300" HeightRequest="350" BackgroundColor="#1A1A2E">
    <Grid RowDefinitions="Auto,*" Padding="10,10,10,4">
        <!-- Title -->
        <Label Text="Bidding (second round)"
               x:Name="BidTitle" FontFamily="Impact" FontSize="16"
               BackgroundColor="#FFD700" TextColor="#1A1A2E"
               HeightRequest="28" Padding="6,0"
               VerticalTextAlignment="Center" HorizontalTextAlignment="Start" />
        <!-- Radio buttons -->
        <VerticalStackLayout Grid.Row="1" Spacing="0" Padding="0,4,0,0">
            <RadioButton Content="Pass" x:Name="Pass" x:FieldModifier="public" GroupName="Bid2" TextColor="White" />
            <RadioButton Content="I choose Hearts" x:Name="Hearts" x:FieldModifier="public" GroupName="Bid2" TextColor="White" />
            <RadioButton Content="I choose Diamonds" x:Name="Diamonds" x:FieldModifier="public" GroupName="Bid2" TextColor="White" />
            <RadioButton Content="I choose Clubs" x:Name="Clubs" x:FieldModifier="public" GroupName="Bid2" TextColor="White" />
            <RadioButton Content="I choose Spades" x:Name="Spades" x:FieldModifier="public" GroupName="Bid2" TextColor="White" />
            <HorizontalStackLayout Spacing="0" Padding="20,0,0,0">
                <CheckBox x:Name="GoingAlone" x:FieldModifier="public" Color="White" VerticalOptions="Center" />
                <Label Text="And I'm Going Alone!" x:Name="GoingAloneLabel" TextColor="White" FontSize="14" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
        <!-- OK button -->
        <Button x:Name="OkButton" Text="OK" Grid.Row="1"
                WidthRequest="75" HeightRequest="36" Margin="0,8,0,0"
                HorizontalOptions="End" VerticalOptions="Start"
                Clicked="OkButton_Click" />
    </Grid>
</ContentView>
