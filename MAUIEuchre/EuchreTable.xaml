<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MAUIEuchre"
             x:Class="MAUIEuchre.EuchreTable"
             Shell.NavBarIsVisible="False"
             Title="Matt's Euchre">

    <Grid BackgroundColor="#1B5E20" ColumnDefinitions="Auto,*,200">

        <!-- Left side buttons -->
        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="10" Padding="8">
            <Button Text="New Game" x:Name="NewGameButton" Clicked="NewGameButton_Click" BackgroundColor="#2E7D32" TextColor="White" CornerRadius="8" FontSize="12" WidthRequest="90">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="3,3" Radius="6" Opacity="0.6" />
                </Button.Shadow>
            </Button>
            <Button Text="Rules" x:Name="RulesButton" Clicked="RulesButton_Click" BackgroundColor="#2E7D32" TextColor="White" CornerRadius="8" FontSize="12" WidthRequest="90">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="3,3" Radius="6" Opacity="0.6" />
                </Button.Shadow>
            </Button>
            <Button Text="About" x:Name="AboutButton" Clicked="AboutButton_Click" BackgroundColor="#2E7D32" TextColor="White" CornerRadius="8" FontSize="12" WidthRequest="90">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="3,3" Radius="6" Opacity="0.6" />
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>

        <Grid Grid.Column="1" x:Name="CenterContainer" SizeChanged="OnCenterContainerSizeChanged">
            <AbsoluteLayout WidthRequest="855" HeightRequest="735" HorizontalOptions="Center" VerticalOptions="Center" AnchorX="0.5" AnchorY="0.5" x:Name="EuchreGrid">
        <Label Text="Your Score: 0" AbsoluteLayout.LayoutBounds="12,39,128,40" AbsoluteLayout.LayoutFlags="None" x:Name="YourScore" BackgroundColor="#CC1A1A2E" TextColor="White" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="13" IsVisible="False" />
        <Label BackgroundColor="#CC1A1A2E" Text="Their Score: 0" TextColor="White" AbsoluteLayout.LayoutBounds="713,39,128,40" AbsoluteLayout.LayoutFlags="None" x:Name="TheirScore" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="13" IsVisible="False" />
        <Grid AbsoluteLayout.LayoutBounds="12,641,144,72" AbsoluteLayout.LayoutFlags="None" x:Name="YourTricksContainer" BackgroundColor="#CC1A1A2E" RowDefinitions="Auto,*" Padding="2">
            <Label Text="Your Tricks:" TextColor="White" HorizontalTextAlignment="Center" FontSize="13" Grid.Row="0" />
            <HorizontalStackLayout x:Name="YourTricksCards" HorizontalOptions="Center" VerticalOptions="Center" Spacing="3" Grid.Row="1" />
        </Grid>
        <Grid AbsoluteLayout.LayoutBounds="697,641,144,72" AbsoluteLayout.LayoutFlags="None" x:Name="TheirTricksContainer" BackgroundColor="#CC1A1A2E" RowDefinitions="Auto,*" Padding="2">
            <Label Text="Their Tricks:" TextColor="White" HorizontalTextAlignment="Center" FontSize="13" Grid.Row="0" />
            <HorizontalStackLayout x:Name="TheirTricksCards" HorizontalOptions="Center" VerticalOptions="Center" Spacing="3" Grid.Row="1" />
        </Grid>
        <Editor AbsoluteLayout.LayoutBounds="12,737,829,81" AbsoluteLayout.LayoutFlags="None" x:Name="StatusAreaHidden" BackgroundColor="#FFF8E1" TextColor="#1A1A2E" IsReadOnly="True" FontSize="13" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="110,127,636,482" AbsoluteLayout.LayoutFlags="None" x:Name="Logo" Aspect="Fill" InputTransparent="True" />

        <!-- Dealer boxes -->
        <Border Stroke="#FFD700" StrokeThickness="2" AbsoluteLayout.LayoutBounds="12,120,128,460" AbsoluteLayout.LayoutFlags="None" x:Name="DealerLeftOpponent" IsVisible="False" BackgroundColor="Transparent" Padding="2,2,0,0" StrokeShape="RoundRectangle 6">
            <Label Text="Dealer" FontAttributes="Bold" TextColor="#FFD700" FontSize="11" VerticalOptions="Start" />
        </Border>
        <Border Stroke="#FFD700" StrokeThickness="2" AbsoluteLayout.LayoutBounds="721,120,128,460" AbsoluteLayout.LayoutFlags="None" x:Name="DealerRightOpponent" IsVisible="False" BackgroundColor="Transparent" Padding="2,2,0,0" StrokeShape="RoundRectangle 6">
            <Label Text="Dealer" FontAttributes="Bold" TextColor="#FFD700" FontSize="11" VerticalOptions="Start" />
        </Border>
        <Border Stroke="#FFD700" StrokeThickness="2" AbsoluteLayout.LayoutBounds="202,18,450,138" AbsoluteLayout.LayoutFlags="None" x:Name="DealerPartner" IsVisible="False" BackgroundColor="Transparent" Padding="2,2,0,0" StrokeShape="RoundRectangle 6">
            <Label Text="Dealer" FontAttributes="Bold" TextColor="#FFD700" FontSize="11" VerticalOptions="Start" />
        </Border>
        <Border Stroke="#FFD700" StrokeThickness="2" AbsoluteLayout.LayoutBounds="202,594,450,138" AbsoluteLayout.LayoutFlags="None" x:Name="DealerPlayer" IsVisible="False" BackgroundColor="Transparent" Padding="2,2,0,0" StrokeShape="RoundRectangle 6">
            <Label Text="Dealer" FontAttributes="Bold" TextColor="#FFD700" FontSize="11" VerticalOptions="Start" />
        </Border>

        <!-- Left Opponent cards (portrait containers, rotated 90° visually) -->
        <Image AbsoluteLayout.LayoutBounds="38,136,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="LeftOpponentCard1" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="38,222,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="LeftOpponentCard2" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="38,308,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="LeftOpponentCard3" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="38,394,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="LeftOpponentCard4" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="38,478,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="LeftOpponentCard5" IsVisible="False" />

        <!-- Right Opponent cards (portrait containers, rotated 270° visually) -->
        <Image AbsoluteLayout.LayoutBounds="747,136,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="RightOpponentCard5" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="747,222,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="RightOpponentCard4" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="747,308,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="RightOpponentCard3" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="747,394,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="RightOpponentCard2" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="747,478,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="RightOpponentCard1" IsVisible="False" />

        <!-- Partner cards -->
        <Image AbsoluteLayout.LayoutBounds="217,43,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="PartnerCard5" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="303,43,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="PartnerCard4" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="389,43,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="PartnerCard3" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="475,43,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="PartnerCard2" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="561,43,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="PartnerCard1" IsVisible="False" />

        <!-- Player cards -->
        <Image AbsoluteLayout.LayoutBounds="217,620,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="PlayerCard1" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="303,620,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="PlayerCard2" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="389,620,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="PlayerCard3" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="475,620,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="PlayerCard4" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="561,620,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="PlayerCard5" IsVisible="False" />

        <!-- Name labels -->
        <Label Text="Left Opponent" AbsoluteLayout.LayoutBounds="33,585,126,28" AbsoluteLayout.LayoutFlags="None" x:Name="LeftOpponentNameLabel" FontSize="13" FontAttributes="Italic" TextColor="#E0E0E0" />
        <Label Text="Right Opponent" AbsoluteLayout.LayoutBounds="743,585,128,28" AbsoluteLayout.LayoutFlags="None" x:Name="RightOpponentNameLabel" FontSize="13" FontAttributes="Italic" TextColor="#E0E0E0" />
        <Label Text="Player's Partner" AbsoluteLayout.LayoutBounds="213,162,97,28" AbsoluteLayout.LayoutFlags="None" x:Name="PartnerNameLabel" FontSize="13" FontAttributes="Italic" TextColor="#E0E0E0" />
        <Label Text="Player" AbsoluteLayout.LayoutBounds="217,576,97,28" AbsoluteLayout.LayoutFlags="None" x:Name="PlayerNameLabel" FontSize="13" FontAttributes="Italic" TextColor="#E0E0E0" />

        <!-- Played cards (center of table) -->
        <Image AbsoluteLayout.LayoutBounds="158,312,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="LeftOpponentCard" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="623,312,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="RightOpponentCard" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="390,162,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="PartnerCard" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="390,476,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="PlayerCard" IsVisible="False" />

        <!-- Kitty cards -->
        <Image AbsoluteLayout.LayoutBounds="635,476,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="KittyCard4" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="626,476,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="KittyCard3" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="611,476,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="KittyCard2" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="600,476,80,104" AbsoluteLayout.LayoutFlags="None" x:Name="KittyCard1" IsVisible="False" />

        <!-- Trump suit indicators -->
        <Image AbsoluteLayout.LayoutBounds="146,410,70,70" AbsoluteLayout.LayoutFlags="None" x:Name="TrumpLeft" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="476,510,70,70" AbsoluteLayout.LayoutFlags="None" x:Name="TrumpPlayer" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="645,248,70,70" AbsoluteLayout.LayoutFlags="None" x:Name="TrumpRight" IsVisible="False" />
        <Image AbsoluteLayout.LayoutBounds="314,162,70,70" AbsoluteLayout.LayoutFlags="None" x:Name="TrumpPartner" IsVisible="False" />

        <!-- Score images -->
        <Image AbsoluteLayout.LayoutBounds="492,162,150,160" AbsoluteLayout.LayoutFlags="None" x:Name="ThemScore" Aspect="Center" />
        <Image AbsoluteLayout.LayoutBounds="218,410,150,160" AbsoluteLayout.LayoutFlags="None" x:Name="UsScore" Aspect="Center" />

        <!-- Select label -->
        <Label Text="Please select a card to play" AbsoluteLayout.LayoutBounds="359,575,200,28" AbsoluteLayout.LayoutFlags="None" x:Name="SelectLabel" FontAttributes="Bold" TextColor="#FFD700" IsVisible="False" />

        <!-- Bid controls -->
        <local:EuchreBidControl AbsoluteLayout.LayoutBounds="278,273,300,190" AbsoluteLayout.LayoutFlags="None" x:Name="BidControl" IsVisible="False" IsEnabled="False" InputTransparent="True" />
        <local:EuchreBid2Control AbsoluteLayout.LayoutBounds="278,193,300,350" AbsoluteLayout.LayoutFlags="None" x:Name="BidControl2" IsVisible="False" IsEnabled="False" InputTransparent="True" />

        <!-- Continue button -->
        <Button Text="Continue" AbsoluteLayout.LayoutBounds="370,324,120,50" AbsoluteLayout.LayoutFlags="None" x:Name="ContinueButton" IsVisible="False" BackgroundColor="#FFD700" TextColor="#1A1A2E" CornerRadius="10" FontSize="16" FontAttributes="Bold">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="3,3" Radius="6" Opacity="0.6" />
            </Button.Shadow>
        </Button>

            </AbsoluteLayout>
        </Grid>

        <!-- Right side: feedback area -->
        <Border Grid.Column="2" BackgroundColor="#FFF8E1" Margin="2,4,4,4" StrokeShape="RoundRectangle 6" Stroke="#C8B560" StrokeThickness="1" Padding="0">
            <ScrollView x:Name="StatusScrollView">
                <Label x:Name="StatusArea" TextColor="#1A1A2E" FontSize="12" Padding="6" LineBreakMode="WordWrap" TextType="Html" />
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>
