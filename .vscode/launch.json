            "preLaunchTask": "build-windows",
            "program": "${workspaceFolder}/MAUIEuchre/bin/Debug/net9.0-windows10.0.19041.0/win10-x64/MAUIEuchre.exe",
            "args": [],
            "cwd": "${workspaceFolder}/MAUIEuchre",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": ".NET Core Launch (console)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/MAUIEuchre/bin/Debug/net9.0-windows10.0.19041.0/win10-x64/MAUIEuchre.dll",
            "args": [],
            "cwd": "${workspaceFolder}/MAUIEuchre",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
